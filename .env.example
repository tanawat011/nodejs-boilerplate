# Application
PORT=3000
NODE_ENV=development
APP_VERSION=1.0.0

# Database (MySQL)
DATABASE_URL="mysql://root:password@localhost:3306/nodejs_boilerplate"

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info
